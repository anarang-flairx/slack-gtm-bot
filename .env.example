SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Set to true to test Slack without OpenAI
DEV_ECHO_MODE=true

# Required when DEV_ECHO_MODE is not true
#OPENAI_API_KEY=sk-your-openai-key

# HubSpot Service Key
HUBSPOT_ACCESS_TOKEN=pat-na1-your-service-key
HUBSPOT_PIPELINE_ID=
HUBSPOT_METHOD_OF_CONTACT_PROPERTY=method_of_contact
HUBSPOT_PORTAL_ID=242879565
HUBSPOT_APP_HOST=app-na2.hubspot.com

# Gmail (compose-only drafts)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=ceo@flairx.com
SENDER_NAME=Abhilasha Juneja

# Resource links for intro-draft template (optional)
GMAIL_AI_REPORT_URL=https://example.com/ai-interview-report
GMAIL_EXPERT_REPORT_URL=https://example.com/expert-interview-report
GMAIL_COMPARISON_REPORT_URL=https://example.com/candidate-comparison-report

# Daily digest (/digest)
DIGEST_CHANNEL=C0123456789
STALL_DAYS_LATE_STAGE=7
STALL_DAYS_EARLY_STAGE=14
FOLLOWUP_DAYS_ATTEMPTED=4
FOLLOWUP_DAYS_CONNECTED=7
DIGEST_MAX_ROWS=8
